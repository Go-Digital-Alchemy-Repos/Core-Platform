# Copy to .env for local development.

# Required: PostgreSQL connection string used by npm run dev and npm run db:push.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/core_platform

# Optional but recommended for stable local sessions.
SESSION_SECRET=dev-secret-change-me

# The dev script defaults to 5001 because port 5000 is commonly used by macOS AirTunes.
PORT=5001

# Optional local URL used in emails, links, and integrations.
APP_URL=http://localhost:5001
